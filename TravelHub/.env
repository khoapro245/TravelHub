# ============================================================
# TravelHub BACKEND (.NET 10) - Environment Variables
# Uses ASP.NET Core's "Section__Key" convention (double underscore)
# so each value maps to the matching key in appsettings.json.
# These override appsettings.json when loaded as environment vars.
# ============================================================

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Development
PORT=8080

# --- Database (SQL Server) ---
ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=TravelHubDB;User Id=sa;Password=123;TrustServerCertificate=True;

# --- JWT Authentication ---
Jwt__Key=TravelHub_Super_Secret_Key_2026_DotNet10_API_Secure
Jwt__Issuer=TravelHubAPI
Jwt__Audience=TravelHubClients
Jwt__AccessTokenExpirationMinutes=1440
Jwt__RefreshTokenExpirationDays=7

# --- Email (SMTP / Gmail) ---
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__SenderName=TravelHub Support
EmailSettings__SenderEmail=khoak871@gmail.com
EmailSettings__Password=your-app-password

# --- Google OAuth ---
GoogleAuth__ClientId=779479919606-hcpsuu5jij6fp6t5ams1595b80q829ko.apps.googleusercontent.com

# --- Gemini AI ---
Gemini__ApiKey=YOUR_GEMINI_API_KEY

# --- Cloudinary (image uploads) ---
Cloudinary__CloudName=dib7cxfie
Cloudinary__ApiKey=941922669964378
Cloudinary__ApiSecret=6yiEOHsj7yYD9kiwo5TCKu4Ywl4

# --- Default Admin Account (seeded on startup) ---
AdminAccount__Email=admin@gmail.com
AdminAccount__Password=12345678
